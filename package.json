{
  "name": "tagscope",
  "displayName": "TagScope",
  "publisher": "CopyPasters",
  "description": "This extension lets you comment the current tag (open + close) with a single shortcut, or comment the entire tag block including its content—no manual selection needed.",
  "version": "0.0.2",
  "icon": "./public/icon.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Islam-abdelwahed/TagScope"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "xmlCommenter.commentTag",
        "title": "XML: Toggle comment on open/close tags"
      },
      {
        "command": "xmlCommenter.commentBlock",
        "title": "XML: Toggle comment on full block"
      }
    ],
    "keybindings": [
      {
        "command": "xmlCommenter.commentTag",
        "key": "ctrl+alt+/",
        "mac": "cmd+alt+/",
        "when": "editorTextFocus && (editorLangId == 'xml' || editorLangId == 'html')"
      },
      {
        "command": "xmlCommenter.commentBlock",
        "key": "ctrl+alt+shift+/",
        "mac": "cmd+alt+shift+/",
        "when": "editorTextFocus && (editorLangId == 'xml' || editorLangId == 'html')"
      }
    ],
    "activationEvents": [
      "onLanguage:xml",
      "onLanguage:html"
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "vsce": {
    "dependencies": false,
    "baseContentUrl": "https://raw.githubusercontent.com/Islam-abdelwahed/TagScope/master/",
    "baseImagesUrl": "https://raw.githubusercontent.com/Islam-abdelwahed/TagScope/master/"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {}
}
